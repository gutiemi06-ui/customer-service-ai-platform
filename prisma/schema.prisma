// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  // Local dev: SQLite  →  DATABASE_URL="file:./prisma/dev.db"
  // Production: PostgreSQL  →  DATABASE_URL="postgresql://..."
  // Switch provider to "postgresql" for Vercel/Neon/Supabase deployments.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums — fields use String with validated values.
// For PostgreSQL (Vercel/Supabase), switch provider to "postgresql"
// and convert String fields back to proper Prisma enum types.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("CUSTOMER") // CUSTOMER | AGENT | ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submittedTickets Ticket[]  @relation("SubmittedBy")
  assignedTickets  Ticket[]  @relation("AssignedTo")
  messages         Message[]
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String // TECHNICAL | BILLING | ACCOUNT | GENERAL
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  userId      String
  agentId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User             @relation("SubmittedBy", fields: [userId], references: [id])
  agent     User?            @relation("AssignedTo", fields: [agentId], references: [id])
  messages  Message[]
  analytics TicketAnalytics?
}

model Message {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String?
  content   String
  isAI      Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?  @relation(fields: [senderId], references: [id])
}

model KBArticle {
  id           String   @id @default(cuid())
  title        String
  content      String
  category     String // TECHNICAL | BILLING | ACCOUNT | GENERAL
  views        Int      @default(0)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TicketAnalytics {
  id                String   @id @default(cuid())
  ticketId          String   @unique
  responseTime      Int? // minutes to first response
  resolutionTime    Int? // minutes to resolution
  satisfactionScore Int? // 1-5 rating
  createdAt         DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
