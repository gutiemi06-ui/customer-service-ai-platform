# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no extra setup needed)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (for Vercel / production — use Neon, Supabase, or Railway)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Your app's base URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for signing sessions — generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# ─── Anthropic Claude API (optional) ─────────────────────────────────────────
# If omitted, the app uses intelligent mock AI responses (fully functional demo)
ANTHROPIC_API_KEY="sk-ant-api03-..."
